# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# DeepSeek API Key (platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-key-here

# 仿真参数
VILLAGE_SIZE=8
TICK_INTERVAL_SECONDS=5
MAX_TICKS=500

# 记忆系统参数
MEMORY_IMPORTANCE_THRESHOLD=150
MEMORY_RECENCY_DECAY=0.995
BELIEF_EXPIRY_DAYS=999

# 日志
LOG_LEVEL=INFO
EXPORT_DIR=../production/session-logs/experiments
